generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  admin     Boolean    @default(false)
  cep       String
  password  String
  cartItems CartItem[]
}

model Product {
  id          String     @id @default(cuid())
  name        String
  description String
  price       Int
  img         String
  createdAt   DateTime   @default(now())
  category    String
  CartItems   CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  productId String
  userId    String
  quantity  Int
  product   Product @relation(fields: [productId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
}
